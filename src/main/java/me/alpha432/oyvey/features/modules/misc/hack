import { useEffect, useState } from "react";

type HighlightedChunkProps = {
  children: React.ReactNode;
  isLoading?: boolean;
  highlightAfterMs?: number;
};

export default function HighlightedChunk({
  children,
  isLoading = false,
  highlightAfterMs = 3000,
}: HighlightedChunkProps) {
  const [shouldHighlight, setShouldHighlight] = useState(false);

  useEffect(() => {
    if (!isLoading) {
      setShouldHighlight(false);
      return;
    }

    const timer = setTimeout(() => {
      setShouldHighlight(true);
    }, highlightAfterMs);

    return () => clearTimeout(timer);
  }, [isLoading, highlightAfterMs]);

  return (
    <div
      className={`transition-all duration-300 rounded-md p-2 ${
        shouldHighlight
          ? "bg-yellow-100 ring-2 ring-yellow-400"
          : ""
      }`}
    >
      {children}
    </div>
  );
